@model Parcial3_Aeropuerto.EN.Paginacion<Parcial3_Aeropuerto.EN.Facturacion>

@{
    ViewData["Title"] = "Facturacion";
}

<h1>Lista de Facturaciones</h1>

<div class="row-md-6 mb-5">
    <form asp-action="Facturacion" method="get" class="d-flex shadow-sm">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="buscar" class="form-control border-start-0"
                   placeholder="Buscar facturaciones por mes..." value="@ViewData["buscar"]" />

            <button type="submit" class="btn btn-primary">
                Buscar
            </button>

            @if (!string.IsNullOrEmpty(Context.Request.Query["buscar"]))
            {
                <a asp-action="Facturacion" class="btn btn-outline-primary">Limpiar</a>
            }

        </div>
    </form>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id Facturacion</th>
            <th>Fecha</th>
            <th>Monto</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Items) {
        <tr>
            <td>@item.Id_Facturacion</td>
            <td>@item.Fecha</td>
            <td>$ @item.Monto</td>
            <td>
                    <a href="javascript:void(0);" class="btn btn-success btn-sm" onclick="mostrarEdit(@item.Id_Facturacion); return false;"><img class="acciones" src="/css/imgs/iconosacciones/editar.png" /></a>
                    <a href="javascript:void(0);" class="btn btn-danger btn-sm" onclick="mostrarDelete(@item.Id_Facturacion);"><img class="acciones" src="/css/imgs/iconosacciones/eliminar.png" /></a>
            </td>
        </tr>
}
    </tbody>
</table>
<nav>
    <ul class="pagination">
        @if (Model.PaginaActual > 1)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Facturacion" asp-route-paginas="@(Model.PaginaActual - 1)">Anterior</a>
            </li>
        }

        @for (int i = 1; i <= Model.TotalPaginas; i++)
        {
            <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                <a class="page-link" asp-action="Facturacion" asp-route-paginas="@i">@i</a>
            </li>
        }

        @if (Model.PaginaActual < Model.TotalPaginas)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Facturacion" asp-route-paginas="@(Model.PaginaActual + 1)">Siguiente</a>
            </li>
        }
    </ul>
</nav>
<div id="modalContainer"></div>

<script>

              function mostrarEdit(id) {
        $.get('/Facturacion/Edit?id=' + id, function (data) {
            $('#modalContainer').html(data);

            var modal = new bootstrap.Modal(document.getElementById('editModal'));
            modal.show();
        });
    }

        function mostrarDelete(id) {
            $.get('/Facturacion/Delete?id=' + id, function (data) {
                $('#modalContainer').html(data);

                var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                modal.show();
            });
        }
</script>