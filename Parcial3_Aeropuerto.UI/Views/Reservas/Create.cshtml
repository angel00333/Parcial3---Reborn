@model Parcial3_Aeropuerto.EN.Reservas

@{
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createModalLabel">Crear Reserva</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
            <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                        <label asp-for="Id_pasajero" class="form-label fw-bold">Id Pasajero</label>

                        <select asp-for="Id_pasajero" id="Id_pasajerox" class="form-select">
                            <option value=""></option>
                            @foreach (var pasajero in ViewBag.Pasajeros)
                            {
                                <option value="@pasajero.Id_pasajero">@pasajero.Nombre @pasajero.Apellido</option>
                            }
                        </select>

                        <span asp-validation-for="Id_pasajero" class="text-danger small"></span>
             </div>

            <div class="mb-3">
                        <label asp-for="Id_vuelo" class="form-label fw-bold">Id Vuelo</label>

                        <select asp-for="Id_vuelo" id="Id_vuelox" class="form-select">
                            <option value=""></option>
                            @foreach (var vuelo in ViewBag.Vuelos)
                            {
                                 if (vuelo.Estado == "En Espera")
                                     {
                                var destinos = ViewBag.Destinos as List<Parcial3_Aeropuerto.EN.Destinos>;
                                var destino = destinos.FirstOrDefault(d => d.Id_destino == vuelo.Id_destino);
                                <option value="@vuelo.Id_vuelo">@vuelo.Id_vuelo - @destino.Nombre_destino | @vuelo.Fecha</option>
                                     }
                            }
                        </select>

                        <span asp-validation-for="Id_vuelo" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Fecha" class="form-label"></label>
                <input asp-for="Fecha" class="form-control" type="date"/>
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Costo" class="form-label"></label>
                <input asp-for="Costo" class="form-control" />
                <span asp-validation-for="Costo" class="text-danger"></span>
            </div>
             <div class="mb-3">
                        <label class="form-label fw-bold">Usuario</label>
                        <input class="form-control" value="@Context.Session.GetString("Usuario")" readonly />
             </div>
            <div class="modal-footer px-0 pb-0">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </form>
    </div>
</div>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script> @*Es la funcion del TomSelect*@

<script>
    //Para los pasajeros
    setTimeout(() => {
    const select = document.querySelector("#Id_pasajerox");

    if (select && !select.tomselect) {
    const ts = new TomSelect("#Id_pasajerox", {
    create: false,
    allowEmptyOption: true,
    maxOptions: 1000,
    searchField: ["text"],
    placeholder: "",
    openOnFocus: true,
    hideSelected: false
    });
    ts.clear(true);
    ts.settings.placeholder = "Seleccione o busque un pasajero";
    ts.inputState();

    ts.on("change", function () {
    $("#Id_pasajerox").valid();
    });
    }
    }, 200);
    //Para los vuelos
    setTimeout(() => {
    const select = document.querySelector("#Id_vuelox");

    if (select && !select.tomselect) {
    const ts = new TomSelect("#Id_vuelox", {
    create: false,
    allowEmptyOption: true,
    maxOptions: 1000,
    searchField: ["text"],
    placeholder: "",
    openOnFocus: true,
    hideSelected: false
    });
    ts.clear(true);
    ts.settings.placeholder = "Seleccione o busque un vuelo por destino";
    ts.inputState();

    ts.on("change", function () {
    $("#Id_vuelox").valid();
    });
    }
    }, 200);
</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
