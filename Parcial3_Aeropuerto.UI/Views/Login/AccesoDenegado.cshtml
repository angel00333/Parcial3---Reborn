@{
    Layout = null;
}

@inject IHttpContextAccessor HttpContextAccessor

@{
    var usuario = Context.Session.GetString("Usuario");
    var rol = Context.Session.GetString("Rol");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso denegado</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" href="~/avion.ico" />

    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #f1f3f5, #dee2e6, #adb5bd);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .access-card {
            width: 390px;
            border: none;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(8px);
            box-shadow: 0 18px 40px rgba(33, 37, 41, 0.18);
            padding: 35px 30px;
            text-align: center;
        }

        .icon-box {
            width: 78px;
            height: 78px;
            border-radius: 50%;
            background: #e9ecef;
            color: #495057;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px auto;
            font-size: 36px;
            box-shadow: inset 0 0 0 1px #ced4da;
        }

        .access-title {
            color: #343a40;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .access-text {
            color: #6c757d;
            font-size: 15px;
            line-height: 1.5;
            margin-bottom: 25px;
        }

        .btn-gray {
            background: #495057;
            color: white;
            border: none;
            border-radius: 12px;
            padding: 11px 22px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-gray:hover {
                background: #343a40;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 18px rgba(33, 37, 41, 0.25);
            }

        .small-note {
            margin-top: 18px;
            font-size: 12px;
            color: #868e96;
        }
    </style>
</head>

<body class="d-flex justify-content-center align-items-center">

    <div class="access-card">
        <div class="icon-box">
            ⚠
        </div>

        <h3 class="access-title">Acceso denegado</h3>


        @if (rol == "Recepcionista" || rol == "Gerente" || rol == "Administrador")
        {
            <p class="access-text">
                No tiene los permisos necesarios para ingresar a esta sección del sistema.
                Si considera que esto es un error, comuníquese con el administrador.
            </p>

            <a asp-controller="Home" asp-action="Index" class="btn btn-gray w-100">
                Volver al inicio
            </a>
        } else
        {
            <p class="access-text">
                No tienes permitido ver esta sección.
            </p>
            <a asp-controller="Login" asp-action="Login" class="btn btn-gray w-100">
                Volver al login
            </a>
        }
        <div class="small-note">
            Sistema Aeropuerto Sauce Plateado
        </div>
    </div>

</body>
</html>