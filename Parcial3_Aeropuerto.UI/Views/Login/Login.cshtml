@model Parcial3_Aeropuerto.EN.Usuarios

@{
    Layout = null;
    var hayError = ViewBag.Error != null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" href="~/avion.ico" />

    <style>
        body {
            background-image: url("/css/imgs/fondosis.png");
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
        }

        .login-contenedor {
            width: 380px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .gatito-login {
            width: 240px;
            margin-bottom: -86px;
            z-index: 5;
            filter: drop-shadow(0px 8px 12px rgba(0,0,0,0.25));
        }

        .login-card {
            width: 350px;
            padding: 80px 30px 30px 30px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.96);
            box-shadow: 0px 8px 25px rgba(0,0,0,0.25);
            z-index: 2;
        }

            .login-card h3 {
                font-weight: bold;
                color: #2b2b2b;
            }

        .form-control {
            border-radius: 12px;
            padding: 10px 12px;
            background-color: #eef4ff;
        }

        .btn-login {
            background: linear-gradient(135deg, #ffb347, #ffcc33);
            border: none;
            color: #3b2a00;
            font-weight: bold;
            border-radius: 12px;
            padding: 11px;
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0px 5px 12px rgba(255, 179, 71, 0.6);
                color: #3b2a00;
            }

        .alert {
            border-radius: 12px;
            font-size: 14px;
        }

        .gatito-triste {
            animation: moverTriste 0.7s ease;
        }

        .gatito-feliz {
            animation: saltarFeliz 0.6s ease;
        }

        @@keyframes moverTriste {
            0% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-6px);
            }

            50% {
                transform: translateX(6px);
            }

            75% {
                transform: translateX(-6px);
            }

            100% {
                transform: translateX(0);
            }
        }

        @@keyframes saltarFeliz {
            0% {
                transform: translateY(0) scale(1);
            }

            50% {
                transform: translateY(-15px) scale(1.05);
            }

            100% {
                transform: translateY(0) scale(1);
            }
        }
    </style>
</head>

<body>

    <div class="login-contenedor">

        <img id="gatitoLogin"
             class="gatito-login @(hayError ? "gatito-triste" : "")"
             src="@(hayError? Url.Content("~/css/imgs/mascota/g_triste.jpeg") : Url.Content("~/css/imgs/mascota/g_quieto.jpeg"))"
             alt="Gatito login" />

        <div class="login-card">

            <h3 class="text-center mb-4">Iniciar Sesión</h3>

            <form asp-controller="Login" asp-action="Login" method="post" id="formLogin">

                <div class="mb-3">
                    <label class="form-label">Usuario</label>
                    <input type="text" name="Nombre_usuario" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input type="password" name="Contraseña" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Entrar
                </button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3 text-center">
                    @ViewBag.Error
                </div>
            }

        </div>
    </div>

    <script>
        const formLogin = document.getElementById("formLogin");
        const gatito = document.getElementById("gatitoLogin");

        formLogin.addEventListener("submit", function () {
            gatito.src = "/css/imgs/mascota/g_feliz.jpeg";
            gatito.classList.remove("gatito-triste");
            gatito.classList.add("gatito-feliz");
        });
    </script>

</body>
</html>