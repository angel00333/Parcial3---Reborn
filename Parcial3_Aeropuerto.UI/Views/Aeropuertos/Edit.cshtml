@model Parcial3_Aeropuerto.EN.Aeropuertos

@{
    Layout = null;
}

<div class="modal fade" id="EditModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">

            <div class="modal-header text-white" style="background: linear-gradient(135deg, #0d6efd, #203C73);">
                <h5 class="modal-title fw-bold" id="editModalLabel">Editar Aeropuerto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <form asp-action="Edit" method="post" id="EditForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input asp-for="Id_aeropuerto" type="hidden" />

                    <div class="form-group mb-3">
                        <label asp-for="Nombre_aeropuerto" class="control-label"></label>
                        <input asp-for="Nombre_aeropuerto" class="form-control" />
                        <span asp-validation-for="Nombre_aeropuerto" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Pais" class="control-label"></label>
                        <input asp-for="Pais" class="form-control" />
                        <span asp-validation-for="Pais" class="text-danger"></span>
                    </div>

                    <div class="modal-footer px-0 pb-0 pt-3">
                        <button type="submit" class="btn btn-primary px-4">Guardar</button>
                        <a asp-action="Aviones" class="btn btn-secondary px-4">Lista Aviones</a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).on("submit", "#EditForm", function (e) {
            e.preventDefault();

        if (!this.checkValidity()) return;

        $.post('/Aeropuertos/Edit', $(this).serialize(), (res) => {

            if (res.includes("modal-body")) {
                $("#modalContainer").html(res);
                new bootstrap.Modal($("#createModal")[0]).show();
                return;
            }

            Swal.fire({
                title: "¡Guardado!",
                text: "El Aeropuerto se actualizó correctamente",
                icon: "info",
                color: "#000000",
                iconColor: "#25E17A",
                timer: 1600,
                showConfirmButton: false,
                confirmButtonColor: "#0136FA"
            });

            bootstrap.Modal.getInstance($("#EditModal")[0]).hide();

            setTimeout(() => {
            location.reload();
            }, 1500); // 🔥 espera que termine la alerta
        });
    });
</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}


