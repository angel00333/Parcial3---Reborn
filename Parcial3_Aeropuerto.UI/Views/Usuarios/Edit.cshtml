@model Parcial3_Aeropuerto.EN.Usuarios

@{
    Layout = null;
}
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editUsuarioLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">

            <div class="modal-header text-white" style="background: linear-gradient(135deg, #0d6efd, #203C73);">
                <h5 class="modal-title fw-bold" id="editUsuarioLabel">Editar Usuario  </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <form asp-action="Edit" method="post" id="EditForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>


                    <div class="mb-3">
                        <input asp-for="Id_usuario" type="hidden" />
                    </div>
                        
                        <div class="mb-4">
                            <label asp-for="Nombre_usuario" class="form-label fw-bold">Nombre Usuario</label>

                            <input asp-for=" Nombre_usuario"
                                   class="form-control" />

                            <span asp-validation-for="Nombre_usuario" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Contraseña" class="form-label fw-bold">Contraseña</label>

                            <input asp-for="Contraseña"
                                   class="form-control" />

                            <span asp-validation-for="Contraseña" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Id_rol" class="form-label fw-bold">Roles</label>

                            <select asp-for="Id_rol"
                                    id="Id_rol"
                                    class="form-select"
                                    placeholder="Seleccione o busque una rol">
                                <option value=""></option>

                                @foreach (var rol in ViewBag.Roles)
                                {
                                    <option value="@rol.Id_rol">@rol.Nombre_rol</option>
                                }
                            </select>

                            <span asp-validation-for="Id_rol" class="text-danger small"></span>
                        </div>


                    <div class="modal-footer px-0 pb-0 pt-3">
                        <button type="submit" class="btn btn-primary px-4">Guardar</button>
                        <a asp-action="Aviones" class="btn btn-secondary px-4">Lista Aviones</a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>

<script>
    setTimeout(() => {
    const select = document.querySelector("#Id_rol_edit");

    if (select && !select.tomselect) {
    const ts = new TomSelect("#Id_rol_edit", {
    create: false,
    allowEmptyOption: true,
    maxOptions: 1000,
    searchField: ["text"],
    placeholder: "Seleccione o busque una aerolínea",
    openOnFocus: true,
    hideSelected: false
    });

    ts.inputState();
    }
    }, 200);
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).on("submit", "#EditForm", function (e) {
            e.preventDefault();

        if (!this.checkValidity()) return;

        $.post('/Usuarios/Edit', $(this).serialize(), (res) => {

            if (res.includes("modal-body")) {
                $("#modalContainer").html(res);
                new bootstrap.Modal($("#createModal")[0]).show();
                return;
            }

            Swal.fire({
                title: "¡Guardado!",
                text: "El Usuario se actualizó correctamente",
                icon: "info",
                color: "#000000",
                iconColor: "#25E17A",
                timer: 1600,
                showConfirmButton: false,
                confirmButtonColor: "#0136FA"
            });

            bootstrap.Modal.getInstance($("#editModal")[0]).hide();

            setTimeout(() => {
            location.reload();
            }, 1500); // 🔥 espera que termine la alerta
        });
    });
</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
