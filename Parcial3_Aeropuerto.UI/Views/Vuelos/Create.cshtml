@model Parcial3_Aeropuerto.EN.Vuelos

@{
    Layout=null;
}

<link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createModalLabel">Crear Vuelo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form asp-action="Create" method="post" id="form-crear-pasajero">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Id_avion" class="form-label fw-bold">Id Avion</label>

                        <select asp-for="Id_avion" id="Id_avionx" class="form-select">
                            <option value=""></option>
                            @foreach (var avion in ViewBag.Aviones)
                            {
                                    var aerolineas = ViewBag.Aerolineas as List<Parcial3_Aeropuerto.EN.Aerolineas>;
                                    var aerolinea = aerolineas?.FirstOrDefault(a => a.Id_aerolinea == avion.Id_aerolinea);
                                    <option value="@avion.Id_avion">Avion N°: @avion.Id_avion - Aerolinea: @aerolinea?.Nombre_aerolinea</option>
                                
                            }
                        </select>

                        <span asp-validation-for="Id_avion" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Id_destino" class="form-label fw-bold">Id Destino</label>

                        <select asp-for="Id_destino" id="Id_destinox" class="form-select">
                            <option value=""></option>
                            @foreach (var destino in ViewBag.Destinos)
                            {
                                <option value="@destino.Id_destino">@destino.Nombre_destino </option>
                            }
                        </select>

                        <span asp-validation-for="Id_destino" class="text-danger small"></span>
                    </div>
            <div class="mb-3">
                <label asp-for="Cantidad_pasajeros" class="form-label"></label>
                <input asp-for="Cantidad_pasajeros" class="form-control" value="0" readonly/>
                <span asp-validation-for="Cantidad_pasajeros" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Fecha" class="form-label"></label>
                <input asp-for="Fecha" class="form-control" type="date"/>
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Tiempo_estimado" class="form-label"></label>
                <input asp-for="Tiempo_estimado" class="form-control" />
                <span asp-validation-for="Tiempo_estimado" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Estado" class="form-label"></label>
                <input asp-for="Estado" class="form-control" />
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Hora_inicio" class="form-label"></label>
                <input asp-for="Hora_inicio" class="form-control" type="time"/>
                <span asp-validation-for="Hora_inicio" class="text-danger"></span>
            </div>
                    <div class="modal-footer px-0 pb-0">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script> @*Es la funcion del TomSelect*@

<script>
    //Para los aviones
    setTimeout(() => {
    const select = document.querySelector("#Id_avionx");

    if (select && !select.tomselect) {
    const ts = new TomSelect("#Id_avionx", {
    create: false,
    allowEmptyOption: true,
    maxOptions: 1000,
    searchField: ["text"],
    placeholder: "",
    openOnFocus: true,
    hideSelected: false
    });
    ts.clear(true);
    ts.settings.placeholder = "Seleccione o busque un avion";
    ts.inputState();

    ts.on("change", function () {
    $("#Id_avionx").valid();
    });
    }
    }, 200);
    //Para los destinos
    setTimeout(() => {
    const select = document.querySelector("#Id_destinox");

    if (select && !select.tomselect) {
    const ts = new TomSelect("#Id_destinox", {
    create: false,
    allowEmptyOption: true,
    maxOptions: 1000,
    searchField: ["text"],
    placeholder: "",
    openOnFocus: true,
    hideSelected: false
    });
    ts.clear(true);
    ts.settings.placeholder = "Seleccione o busque un destino";
    ts.inputState();

    ts.on("change", function () {
    $("#Id_destinox").valid();
    });
    }
    }, 200);
</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}

