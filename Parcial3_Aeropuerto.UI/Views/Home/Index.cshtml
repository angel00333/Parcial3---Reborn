@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor httpContextAccessor

@{
    var usuario = Context.Session.GetString("Usuario");
    ViewData["Title"] = "Home Page";
}

<style>
    html, body {
        min-height: 100vh;
        overflow-y: hidden;
    }

    .day-night-icon {
        position: fixed;
        top: 130px;
        right: 10px;
        width: 70px;
        height: 70px;
        z-index: 999;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .day-night-icon img {
            width: 100px;
            height: 100px;
            object-fit: contain;
            animation: flotando 2s ease-in-out infinite alternate;
        }

    @@keyframes flotando {
        from {
            transform: translateY(0);
        }

        to {
            transform: translateY(-5px);
        }
    }

    .welcome-card {
        margin-top: 120px;
        padding: 40px;
        border-radius: 25px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
        display: inline-block;
    }

        .welcome-card h1 {
            color: #1b1f4a;
            font-weight: 700;
        }

        .welcome-card h2 {
            color: #4a5568;
            font-weight: 500;
        }
</style>

<div id="dayNightIcon" class="day-night-icon">
    <img id="iconShape" src="" alt="Icono día noche" />
</div>

<div class="text-center">
    <div class="welcome-card">
        <h1 class="display-4">Bienvenido/a, @ViewBag.Saludo</h1>
        <h2>@usuario</h2>
    </div>
</div>

<script>
    const hora = new Date().getHours();
    const icono = document.getElementById("iconShape");

    // Día: 6:00 a.m. a 5:59 p.m.
    // Noche: 6:00 p.m. a 5:59 a.m.
    if (hora >= 6 && hora < 18) {
        icono.src = "/css/imgs/tiempo/sol.jpeg";
    } else {
        icono.src = "/css/imgs/tiempo/luna.jpeg";
    }
</script>