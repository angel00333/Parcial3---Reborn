@model Parcial3_Aeropuerto.EN.Paginacion<Parcial3_Aeropuerto.EN.Aerolineas>

@{
    ViewData["Title"] = "Aerolineas";
}

<h1>Aerolineas</h1>

<p>
    <a href="javascript:void(0)" class="btn btn-primary" onclick="mostrarCreate()"><img class="acciones" src="~/css/imgs/iconosacciones/agregar.png" /></a>
</p>

<div class="row-md-6 mb-5">
    <form asp-action="Aerolineas" method="get" class="d-flex shadow-sm">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="buscar" class="form-control border-start-0"
                   placeholder="Buscar por nombre o apellido..." value="@ViewData["buscar"]" />

            <button type="submit" class=" btn btn-primary">
                Buscar
            </button>

            @if (!string.IsNullOrEmpty(Context.Request.Query["buscar"]))
            {
                <a asp-action="Aerolineas" class="btn btn-outline-secondary">Limpiar</a>
            }

        </div>
    </form>


</div>


<table class="table table-striped">
    <thead>
        <tr>
            <th>Id Aerolineas</th>
            <th>Nombre Aerolinea</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Items) {
        <tr>
           <td>@Html.DisplayFor(modelItem => item.Id_aerolinea)</td>
           <td>@Html.DisplayFor(modelItem => item.Nombre_aerolinea)</td>

             <td>
                <a href="javascript:void(0);" class="btn btn-success btn-sm" onclick="mostrarEdit(@item.Id_aerolinea); return false;"><img class="acciones" src="/css/imgs/iconosacciones/editar.png" /></a>
                <a href="javascript:void(0);" class="btn btn-danger btn-sm" onclick="mostrarDelete(@item.Id_aerolinea);"><img class="acciones" src="/css/imgs/iconosacciones/eliminar.png" /></a>
            </td>
        </tr>

}
    </tbody>
</table>
<nav>
    <ul class="pagination">
        @if (Model.PaginaActual > 1)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Aerolineas" asp-route-paginas="@(Model.PaginaActual - 1)">Anterior</a>
            </li>
        }

        @for (int i = 1; i <= Model.TotalPaginas; i++)
        {
            <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                <a class="page-link" asp-action="Aerolineas" asp-route-paginas="@i">@i</a>
            </li>
        }

        @if (Model.PaginaActual < Model.TotalPaginas)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Aerolineas" asp-route-paginas="@(Model.PaginaActual + 1)">Siguiente</a>
            </li>
        }
    </ul>
</nav>

<div id="modalContainer"></div>

<script>
        function mostrarCreate() {
            $.get('/Aerolineas/Create', function (data) {
                $('#modalContainer').html(data);

                var modal = new bootstrap.Modal(document.getElementById('createModal'));
                modal.show();
            });
        }

              function mostrarEdit(id) {
        $.get('/Aerolineas/Edit?id=' + id, function (data) {
            $('#modalContainer').html(data);

            var modal = new bootstrap.Modal(document.getElementById('editModal'));
            modal.show();
        });
    }

        function mostrarDelete(id) {
            $.get('/Aerolineas/Delete?id=' + id, function (data) {
                $('#modalContainer').html(data);

                var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                modal.show();
            });
        }
</script>

@*LLamo la fucnion de alerta desde aquí por motivos de procesamiento de datos de validación_NG*@
@if (TempData["SMSExito"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        Swal.fire({
        title: "¡Excelente!",
        text: '@Html.Raw(TempData["SMSExito"])',
        icon: "success",
        color: "#000000",
        iconColor: "#25E17A",
        timer: 1500,
        showConfirmButton: false
        });
    </script>
    
}
@{
    var smsExito = TempData["SMSExito"]?.ToString();
    var smsError = TempData["SMSError"]?.ToString();
}

@if (!string.IsNullOrWhiteSpace(smsError))
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        Swal.fire({
        title: "No se puede eliminar",
        text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(smsError)),
        icon: "warning",
        color: "#000000",
        iconColor: "#F5650C",
        confirmButtonText: "Entendido"
        });
    </script>
}
else if (!string.IsNullOrWhiteSpace(smsExito))
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        Swal.fire({
        title: "¡Excelente!",
        text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(smsExito)),
        icon: "success",
        color: "#000000",
        iconColor: "#25E17A",
        timer: 1500,
        showConfirmButton: false
        });
    </script>
}