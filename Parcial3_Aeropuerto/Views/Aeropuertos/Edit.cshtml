@model Parcial3_Aeropuerto.Models.Aeropuertos

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Aeropuertos_Edición</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Id_aeropuerto" class="control-label"></label>
                <input asp-for="Id_aeropuerto" class="form-control" />
                <span asp-validation-for="Id_aeropuerto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Nombre_aeropuerto" class="control-label"></label>
                <input asp-for="Nombre_aeropuerto" class="form-control" />
                <span asp-validation-for="Nombre_aeropuerto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Pais" class="control-label"></label>
                <input asp-for="Pais" class="form-control" />
                <span asp-validation-for="Pais" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                 <a asp-action="Aeropuertos" class="btn btn-secondary">Regresar</a>
            </div>
        </form>
    </div>
</div>



