@model Parcial3_Aeropuerto.EN.Aeropuertos

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Aeropuertos_Edición</h4>
<hr />
<div class="modal fade" id="EditModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            
            <div class="modal-header text-white" style="background: linear-gradient(135deg, #0d6efd, #203C73);">
                <h5 class="modal-title fw-bold" id="editUsuarioLabel">Editar Aeropuerto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form asp-action="Edit" asp-controller="Aeropuertos" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input asp-for="Id_aeropuerto" type="hidden" />

                    <div class="form-group mb-3">
                        <label asp-for="Nombre_aeropuerto" class="control-label"></label>
                        <input asp-for="Nombre_aeropuerto" class="form-control" />
                        <span asp-validation-for="Nombre_aeropuerto" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Pais" class="control-label"></label>
                        <input asp-for="Pais" class="form-control" />
                        <span asp-validation-for="Pais" class="text-danger"></span>
                    </div>

                    <div class="modal-footer px-0 pb-0">
                        <button type="submit" class="btn btn-primary">Guardar cambios</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}


