@model Parcial3_Aeropuerto.Models.Aeropuertos

@{
    // IMPORTANTE: Layout null para que no cargue el banner azul ni el fondo dos veces
    Layout = null;
}

<div class="modal fade" id="Create" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalLabel">
                    <i class="bi bi-airplane-fill me-2"></i> Registrar Nuevo Aeropuerto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <form asp-action="Create" method="post" id="form-create-aeropuerto">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input asp-for="Id_aeropuerto" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Nombre_aeropuerto" class="form-label fw-bold">Nombre del Aeropuerto</label>
                        <input asp-for="Nombre_aeropuerto" class="form-control" placeholder="Escribe el nombre" required />
                        <span asp-validation-for="Nombre_aeropuerto" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Pais" class="form-label fw-bold">País</label>
                        <input asp-for="Pais" class="form-control" placeholder="Escribe el pais" required />
                        <span asp-validation-for="Pais" class="text-danger"></span>
                    </div>

                    <div class="modal-footer px-0 pb-0 pt-3">
                        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary px-4">Guardar Aeropuerto</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    (function () {
        const formulario = document.getElementById("form-create-aeropuerto");

        if (formulario) {
            formulario.addEventListener("submit", function (e) {
                e.preventDefault();

                Swal.fire({
                    title: "¡Excelente!",
                    text: "Guardando los datos del aeropuerto...",
                    icon: "success",
                    timer: 1500,
                    showConfirmButton: false,
                    timerProgressBar: true
                }).then(() => {
                    formulario.submit();
                });
            });
        }
    })();
</script>

@{
    // Scripts de validación para que no mande campos vacíos
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}