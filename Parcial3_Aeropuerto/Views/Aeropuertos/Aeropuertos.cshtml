@model IEnumerable<Parcial3_Aeropuerto.EN.Aeropuertos>

@{
    ViewData["Title"] = "Aeropuertos";
}

<h1>Datos Aeropuerto</h1>

<p>
    <a href="javascript:void()" class="btn btn-primary" onclick="mostrarCreate()">Nuevo Avion</a>
</p>

<div class="row-md-6 mb-5">
    <form asp-action="Aeropuertos" method="get" class="d-flex shadow-sm">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="buscar" class="form-control border-start-0"
                   placeholder="Buscar por nombre o pais..." value="@ViewData["buscar"]" />

            <button type="submit" class=" btn text-white" style="background-color: blue">
                Buscar
            </button>

            @if (!string.IsNullOrEmpty(Context.Request.Query["buscar"]))
            {
                <a asp-action="Aeropuertos" class="btn btn-outline-secondary">Limpiar</a>
            }

        </div>
    </form>


</div>
<table class="table table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id_aeropuerto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre_aeropuerto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Pais)
            </th>
            <th>
                Acciones
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id_aeropuerto)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre_aeropuerto)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Pais)
            </td>
            <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.Id_aeropuerto }) |
                     @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                    @Html.ActionLink("Delete", "Delete", new { id=item.Id_aeropuerto })
            </td>
        </tr>
}
    </tbody>
</table>
    <div id="modalContainer"></div>

    <script>
        function mostrarCreate() {
           
            $.get('/Aeropuertos/Create', function (data) {
               
                $('#modalContainer').html(data);
            
                var modalElem = document.getElementById('Create');
                if (modalElem) {
                    var modal = new bootstrap.Modal(modalElem);
                    modal.show();
                } else {
                    console.error("No se encontró un elemento con ID 'Create' en la vista parcial.");
                }
            });
        }
    </script>