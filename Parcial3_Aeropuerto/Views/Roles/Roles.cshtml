@model IEnumerable<Parcial3_Aeropuerto.EN.Rol>

@{
    ViewData["Title"] = "Roles";
}

<h1>Roles</h1>

<p>
    <a href="javascript:void(0)" class="btn btn-primary" onclick="mostrarCreate()"><img class="acciones" src="~/css/imgs/iconosacciones/agregar.png" /></a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id_rol)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre_rol)
            </th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id_rol)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre_rol)
            </td>
            <td>
                    <a href="javascript:void(0);" class="btn btn-success btn-sm" onclick="mostrarEdit(@item.Id_rol); return false;"><img class="acciones" src="/css/imgs/iconosacciones/editar.png" /></a>

                    <a href="javascript:void(0);" class="btn btn-danger btn-sm" onclick="mostrarDelete(@item.Id_rol);"><img class="acciones" src="/css/imgs/iconosacciones/eliminar.png" /></a>
            </td>
        </tr>
}
    </tbody>
</table>

  <div id="modalContainer"></div>

    <script>

        function mostrarCreate() {
        $.get('/Roles/Create', function (data) {
            $('#modalContainer').html(data);
            var modal = new bootstrap.Modal(document.getElementById('createModal'));
            modal.show();
        });
    }

    function mostrarEdit(id) {
    $.get('/Roles/Edit?id=' + id, function (data) {
        $('#modalContainer').html(data);
        var modal = new bootstrap.Modal(document.getElementById('editModal'));
        modal.show();
    });
}

function mostrarDelete(id) {
        $.get('/Roles/Delete?id=' + id, function (data) {
            $('#modalContainer').html(data);
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        });
    }
    </script>
