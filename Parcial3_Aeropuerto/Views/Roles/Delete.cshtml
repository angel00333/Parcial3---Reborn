@model Parcial3_Aeropuerto.Models.Rol

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

    
<div class="container mt-5">
    <div class="card shadow">

            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Eliminar Registro</h4>
            </div>

        <div class="card-body">



                    <h5 class="text-danger mb-4">
                        ¿Estás seguro de eliminar este registro?
                    </h5>

                    <h4>Rol</h4>
                    <hr />
                    <dl class="row">
                        <dt class="col-sm-2">
                            @Html.DisplayNameFor(model => model.Id_rol)
                        </dt>
                        <dd class="col-sm-10">
                            @Html.DisplayFor(model => model.Id_rol)
                        </dd>
                        <dt class="col-sm-2">
                            @Html.DisplayNameFor(model => model.Nombre_rol)
                        </dt>
                        <dd class="col-sm-10">
                            @Html.DisplayFor(model => model.Nombre_rol)
                        </dd>
                    </dl>

                    <form asp-action="Delete" method="post" class="form-eliminar">
                        <input type="hidden" asp-for="Id_rol" />
        
                        <input type="submit" value="Eliminar" class="btn btn-danger" />
                        <a asp-action="Roles" class="btn btn-secondary">Cancelar</a>
                    </form>

            </div>
        </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.querySelectorAll(".form-eliminar").forEach(form => {
    form.addEventListener("submit", function (e) {
    e.preventDefault();

    Swal.fire({
    title: "¿Estás seguro?",
    icon: "warning",
    iconColor: "#FB0700",
    showCancelButton: true,
    confirmButtonText: "Sí, eliminar",
    confirmButtonColor: "#F46958",
    cancelButtonColor: "#6c757d",
    }).then((result) => {
    if (result.isConfirmed) {

    // 🔥 alerta con tiempo
    Swal.fire({
    title: "Eliminado",
    text: "Se eliminó correctamente",
    icon: "success",
    iconColor: "#37FB00",
    timer: 1050, //Temporixador XD
    timerProgressBar: true,
    showConfirmButton: false
    }).then(() => {
    form.submit(); // se envía después del tiempo xd
    });

    }
    });
    });
    });
</script>



