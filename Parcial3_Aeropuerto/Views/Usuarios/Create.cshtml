@model Parcial3_Aeropuerto.EN.Usuarios
@{
    Layout = null;
}

<div class="modal fade" id="Create" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Registrar Nuevo Avión</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Create" method="post" id="form-crear-usuario">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                 
                    <input asp-for="Id_usuario" type="hidden" />

                    
                    <div class="mb-3">
                        <label asp-for="Nombre_usuario" class="form-label">Nombre de Usuario</label>
                        <input asp-for="Nombre_usuario" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Contraseña" class="form-label">Contraseña</label>

                        <input asp-for="Contraseña" type="password" class="form-control" required />

                        <span asp-validation-for="Contraseña" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Aerolínea</label>

                        <select asp-for="Id_rol" class="form-control">
                            <option value="">--|Seleccione un Rol XD| --</option>

                            @foreach (var rl in ViewBag.Roles)
                            {
                                <option value="@rl.Id_rol">
                                    @rl.Nombre_rol
                                </option>
                            }
                        </select>
                    </div>


                    <div class="modal-footer px-0 pb-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar Usuario</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>




@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}