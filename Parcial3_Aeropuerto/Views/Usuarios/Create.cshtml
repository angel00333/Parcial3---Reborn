@model Parcial3_Aeropuerto.EN.Usuarios

@{
    Layout = null;
}
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet"> @*Toco usar la libreria TomSelect para poder darle estilacho_NM*@

<div class="modal fade" id="CreateModal" tabindex="-1" aria-labelledby="modalRolLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">

            <div class="modal-header text-white" style="background: linear-gradient(135deg, #0d6efd, #203C73);">
                <h5 class="modal-title fw-bold" id="modalAvionLabel">
                    <i class="bi bi-airplane-engines-fill me-2"></i> Registrar Nuevo Usuario
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <form asp-action="Create" method="post" id="form-crear-rol">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                 
                    <div class="mb-4">
                        <label asp-for="Nombre_usuario" class="form-label fw-bold">Nombre de Usuario</label>

                        <input asp-for="Nombre_usuario"
                               class="form-control" />

                        <span asp-validation-for="Nombre_usuario" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Contraseña" class="form-label fw-bold">Contraseña</label>       
                        <input asp-for="Contraseña"
                               class="form-control" />

                        <span asp-validation-for="Contraseña" class="text-danger small"></span>
                    </div>


                    <div class="mb-3">
                        <label asp-for="Id_rol" class="form-label fw-bold">Roles</label>

                        <select asp-for="Id_rol"
                                id="Id_rol"
                                class="form-select"
                                placeholder="Seleccione o busque una rol"
                                >
                            <option value=""></option>

                            @foreach (var rol in ViewBag.Roles)
                            {
                                <option value="@rol.Id_rol">@rol.Nombre_rol</option>
                            }
                        </select>

                        <span asp-validation-for="Id_rol" class="text-danger small"></span>
                    </div>  

                    <div class="modal-footer px-0 pb-0 pt-3">
                        <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <button type="submit" class="btn btn-primary px-4">
                            Guardar Avión
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script> @*Es la funcion del TomSelect*@
<script>
    setTimeout(() => {
    const select = document.querySelector("#Id_rol");

    if (select && !select.tomselect) {
    const ts = new TomSelect("#Id_rol", {
    create: false,
    allowEmptyOption: true,
    maxOptions: 1000,
    searchField: ["text"],
    placeholder: "",
    openOnFocus: true,
    hideSelected: false
    });
    ts.clear(true);
    ts.settings.placeholder = "Seleccione o busque un rol....";
    ts.inputState();

    ts.on("change", function () {
    $("#Id_rol").valid();
    });
    }
    }, 200);
</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}